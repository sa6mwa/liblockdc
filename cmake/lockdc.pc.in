prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: lockdc
Description: lockd client library for C
Version: @PROJECT_VERSION@
Cflags: -I${includedir}
Libs: -L${libdir} -llockdc
Libs.private: -L${libdir} -lpslog -llonejson -lcurl -lssh2 -lz -lssl -lcrypto -lnghttp2 -lpthread @CMAKE_DL_LIBS@
