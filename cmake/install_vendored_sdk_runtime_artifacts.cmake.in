lockdc_install_optional_glob("lib" "@LOCKDC_EXTERNAL_ROOT@/nghttp2/install/lib/libnghttp2@CMAKE_SHARED_LIBRARY_SUFFIX@*")
lockdc_install_optional_glob("lib" "@LOCKDC_EXTERNAL_ROOT@/libssh2/install/lib/libssh2@CMAKE_SHARED_LIBRARY_SUFFIX@*")
lockdc_install_optional_glob("lib" "@LOCKDC_EXTERNAL_ROOT@/zlib/install/lib/libz@CMAKE_SHARED_LIBRARY_SUFFIX@*")
