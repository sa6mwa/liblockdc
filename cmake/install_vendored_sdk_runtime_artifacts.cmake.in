function(lockdc_install_optional_glob destination pattern)
    file(GLOB _matching_files "${pattern}")
    if(_matching_files)
        file(INSTALL
            DESTINATION "${CMAKE_INSTALL_PREFIX}/${destination}"
            TYPE FILE
            FILES ${_matching_files}
        )
    endif()
endfunction()

lockdc_install_optional_glob("lib" "@LOCKDC_EXTERNAL_ROOT@/pslog/install/lib/libpslog@CMAKE_SHARED_LIBRARY_SUFFIX@*")
lockdc_install_optional_glob("lib" "@LOCKDC_EXTERNAL_ROOT@/curl/install/lib/libcurl@CMAKE_SHARED_LIBRARY_SUFFIX@*")
