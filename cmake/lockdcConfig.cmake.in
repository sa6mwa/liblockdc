@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(lockdc_INCLUDE_DIR "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_INCLUDEDIR@")
set(lockdc_LIBRARY_DIR "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_LIBDIR@")

find_dependency(Threads REQUIRED)

if(NOT TARGET lockdc::shared AND NOT "@LOCKDC_SHARED_LINK_NAME@" STREQUAL "" AND EXISTS "${lockdc_LIBRARY_DIR}/@LOCKDC_SHARED_LINK_NAME@")
  set(_lockdc_shared_links)
  list(APPEND _lockdc_shared_links curl pslog nghttp2 ssh2 ssl crypto z lonejson)
  list(APPEND _lockdc_shared_links Threads::Threads)
  if(NOT "@CMAKE_DL_LIBS@" STREQUAL "")
    list(APPEND _lockdc_shared_links "@CMAKE_DL_LIBS@")
  endif()
  if(NOT "@LOCKDC_EXPORTED_ATOMIC_LIBRARY@" STREQUAL "")
    list(APPEND _lockdc_shared_links "@LOCKDC_EXPORTED_ATOMIC_LIBRARY@")
  endif()
  if(NOT "@LOCKDC_COVERAGE_RUNTIME_LIBRARY@" STREQUAL "")
    list(APPEND _lockdc_shared_links "@LOCKDC_COVERAGE_RUNTIME_LIBRARY@")
  endif()
  if(APPLE)
    list(APPEND _lockdc_shared_links "-framework CoreFoundation" "-framework SystemConfiguration")
  endif()

  add_library(lockdc::shared SHARED IMPORTED)
  set_target_properties(lockdc::shared PROPERTIES
    IMPORTED_LOCATION "${lockdc_LIBRARY_DIR}/@LOCKDC_SHARED_LINK_NAME@"
    INTERFACE_INCLUDE_DIRECTORIES "${lockdc_INCLUDE_DIR}"
    INTERFACE_LINK_LIBRARIES "${_lockdc_shared_links}"
  )
endif()

if(NOT TARGET lockdc::static AND EXISTS "${lockdc_LIBRARY_DIR}/liblockdc.a")
  set(_lockdc_static_links)
  list(APPEND _lockdc_static_links curl pslog nghttp2 ssh2 ssl crypto z lonejson)
  list(APPEND _lockdc_static_links Threads::Threads)
  if(NOT "@CMAKE_DL_LIBS@" STREQUAL "")
    list(APPEND _lockdc_static_links "@CMAKE_DL_LIBS@")
  endif()
  if(NOT "@LOCKDC_EXPORTED_ATOMIC_LIBRARY@" STREQUAL "")
    list(APPEND _lockdc_static_links "@LOCKDC_EXPORTED_ATOMIC_LIBRARY@")
  endif()
  if(NOT "@LOCKDC_COVERAGE_RUNTIME_LIBRARY@" STREQUAL "")
    list(APPEND _lockdc_static_links "@LOCKDC_COVERAGE_RUNTIME_LIBRARY@")
  endif()
  if(APPLE)
    list(APPEND _lockdc_static_links "-framework CoreFoundation" "-framework SystemConfiguration")
  endif()

  add_library(lockdc::static STATIC IMPORTED)
  set_target_properties(lockdc::static PROPERTIES
    IMPORTED_LOCATION "${lockdc_LIBRARY_DIR}/liblockdc.a"
    INTERFACE_INCLUDE_DIRECTORIES "${lockdc_INCLUDE_DIR}"
    INTERFACE_LINK_LIBRARIES "${_lockdc_static_links}"
  )
endif()

check_required_components(lockdc)
